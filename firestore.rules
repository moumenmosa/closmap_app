rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userRole(uid) {
      return userDoc(uid).data.role;
    }

    function isAdmin() {
      return signedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && userRole(request.auth.uid) == 'admin')
        || request.auth.token.email == 'admin@closemap.demo'
      );
    }

    function isEmployer() {
      return signedIn() && userRole(request.auth.uid) == 'employer';
    }

    function isSeeker() {
      return signedIn() && userRole(request.auth.uid) == 'seeker';
    }

    function validNotificationPrefs(prefs) {
      return prefs is map
        && prefs.keys().hasOnly(['pushType1', 'pushType2', 'pushType3', 'emailOnMatch'])
        && prefs.pushType1 is bool
        && prefs.pushType2 is bool
        && prefs.pushType3 is bool
        && prefs.emailOnMatch is bool;
    }

    // ---------- Users ----------
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['notificationPrefs'])
        || validNotificationPrefs(request.resource.data.notificationPrefs)
      );
      allow delete: if false;
    }

    // ---------- Job seeker profiles ----------
    match /seekerProfiles/{uid} {
      allow read: if signedIn();
      allow create, update: if isSelf(uid);
      allow delete: if false;
    }

    // ---------- Employer profiles ----------
    match /employerProfiles/{uid} {
      allow read: if signedIn();
      allow create, update: if isSelf(uid);
      allow delete: if false;
    }

    // ---------- Jobs ----------
    match /jobs/{jobId} {
      allow read: if signedIn();
      allow create: if isEmployer() && request.resource.data.employerId == request.auth.uid;
      allow update: if signedIn() && (
        // owner can edit own post
        resource.data.employerId == request.auth.uid
        // seekers may only bump counters via application flow
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['applicantsCount', 'updatedAt'])
      );
      allow delete: if signedIn() && resource.data.employerId == request.auth.uid;
    }

    // ---------- Applications ----------
    match /applications/{appId} {
      allow read: if signedIn() && (
        resource.data.seekerId == request.auth.uid
        || resource.data.employerId == request.auth.uid
      );
      allow create: if isSeeker() && request.resource.data.seekerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.seekerId == request.auth.uid
        || resource.data.employerId == request.auth.uid
      );
      allow delete: if signedIn() && resource.data.seekerId == request.auth.uid;
    }

    // ---------- Saved jobs ----------
    match /savedJobs/{savedId} {
      allow read, write: if signedIn() && (
        (resource == null && request.resource.data.seekerId == request.auth.uid)
        || (resource != null && resource.data.seekerId == request.auth.uid)
      );
    }

    // ---------- Matched jobs ----------
    match /matchedJobs/{matchId} {
      allow read, write: if signedIn() && (
        (resource == null && request.resource.data.seekerId == request.auth.uid)
        || (resource != null && resource.data.seekerId == request.auth.uid)
      );
    }

    // ---------- Profile view requests ----------
    match /viewRequests/{reqId} {
      allow read: if signedIn() && (
        resource.data.seekerId == request.auth.uid
        || resource.data.employerId == request.auth.uid
      );
      allow create: if isEmployer() && request.resource.data.employerId == request.auth.uid;
      // seeker approves / rejects
      allow update: if signedIn() && resource.data.seekerId == request.auth.uid;
      allow delete: if false;
    }

    // ---------- Exploring spots ----------
    match /exploringSpots/{spotId} {
      allow read: if signedIn();
      allow create: if isSeeker() && request.resource.data.seekerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.seekerId == request.auth.uid;
    }

    // ---------- Transactions ----------
    match /transactions/{txId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------- Notifications ----------
    match /notifications/{uid}/items/{nid} {
      allow read, update, delete: if isSelf(uid);
      // any signed-in user may create a notification for another user
      // (e.g. employer notifies seeker of status change)
      allow create: if signedIn();
    }

    // ---------- Plans & point packages (seeded, read-only) ----------
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pointPackages/{pkgId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- Lookups (job titles, sectors, skills...) ----------
    match /lookups/{docId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly(['values'])
        && request.resource.data.values is list;
      allow delete: if isAdmin();
    }

    // ---------- Login attempt tracking ----------
    match /loginAttempts/{email} {
      allow read, write: if true;
    }

    // ---------- Leaderboard (seeded, read-only) ----------
    match /leaderboard/{entryId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
